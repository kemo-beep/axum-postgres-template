APP_ENVIRONMENT=development
PORT=8080

DATABASE_URL="postgres://postgres:password@127.0.0.1:5432/example"
DATABASE_POOL_MAX_SIZE=50
# Used in tests to remove the database prefix from DATABASE_URL and replace it with a random database name.
DATABASE_NAME="example"

# Auth (required for auth endpoints)
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRY_SECS=3600
# Login lockout: max failed attempts (default 5), 0 = disabled
# LOGIN_LOCKOUT_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_DURATION_MINUTES=15

# SMTP (optional; unset = log-only in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@example.com

# R2 / S3 storage (optional; requires Rust 1.91+)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# CORS (comma-separated origins, or * for any)
# CORS_ORIGINS=*

# Base URL for OAuth redirect (e.g. http://localhost:8080 or https://api.example.com)
# BASE_URL=http://localhost:8080

# Frontend app URL. When set, Google OAuth callback redirects here with ?token= instead of returning JSON.
# FRONTEND_URL=http://localhost:3005

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3005
# Configures which modules tracing_subscriber emits logs for.
# Example: server=debug,tower_http=info,sqlx=info
# To hide HTTP request trace: tower_http=warn
RUST_LOG=server=debug,tower_http=info,sqlx=info
